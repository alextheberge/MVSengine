#!/usr/bin/env bash
# SPDX-License-Identifier: AGPL-3.0-only
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "${repo_root}"

if ! command -v make >/dev/null 2>&1; then
  echo "pre-commit blocked: 'make' is required" >&2
  exit 1
fi

echo "[pre-commit] running MVS manifest gate..."
make run-precommit
